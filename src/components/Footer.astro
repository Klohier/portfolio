<style>
  .post-cta {
    margin-top: 3rem;
    padding-top: 2rem;
    padding-bottom: 3rem;
    border-top: 1px solid var(--blue-7);
    text-align: center;
  }

  .post-cta p {
    font-size: 1rem;
    opacity: 0.8;
    margin-bottom: 1rem;
  }

  .cta-links {
    display: flex;
    justify-content: center;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .cta-links a {
    display: inline-block;
    padding: 0.4rem 1rem;
    border: 1px solid var(--blue-7);
    border-radius: 999px;
    font-size: 0.9rem;
    color: var(--text-color);
