  .cta-links a:hover {
    background: var(--blue-9);
    border-color: var(--blue-8);
    text-decoration: none;
  }

  .webring {
    margin-top: 1.5rem;
    font-size: 0.85rem;
    opacity: 0.7;
  }
</style>

