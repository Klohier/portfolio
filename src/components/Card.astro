---
const { class: className, variant } = Astro.props;
---

<div class:list={["card", variant && `card--${variant}`, className]}>
  <slot />
</div>

<style>
  .card {
    background-color: var(--card-background-color);
    border: var(--blue-6) 1px solid;
    border-radius: 8px;
    padding: 1rem;
    box-shadow: 0 4px 6px var(--slate-1);
    transition: box-shadow 0.3s ease;
    position: relative;
    height: 100%;
  }

  .card p {
    line-height: 1.6;
  }

  .card:hover {
    box-shadow:
      0 4px 6px var(--blue-9),
      0 0 20px var(--blue-9),
      0 0 40px var(--blue-9);
  }

  .card--social {
    max-width: 55%;
    margin: auto;
    padding: 0.5rem;
    display: flex;
    justify-content: center;
    align-items: center;
    aspect-ratio: 1;
  }

  .card--social :global(img),
  .card--social :global(svg) {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }
</style>
