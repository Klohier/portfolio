<style>
  .nav-links {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 2rem;
    width: 100%;
    flex-direction: row;
  }

  .nav-links a {
    padding: 0.5rem 0;
    text-decoration: none;
    font-size: 1rem;
    font-weight: 600;
    text-transform: uppercase;
    color: var(--text-color);
    position: relative;
    transition: color 0.3s ease;
    letter-spacing: 0.5px;
  }

  /* Adds line underneath */
  .nav-links a::before {
    content: "";
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 2px;
    background: var(--blue-6);
    transition: opacity 0.3s ease;
  }

  /* Animated gradient underline */
  .nav-links a::after {
    content: "";
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 2px;
    background-color: var(--blue-9);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.4s ease;
  }

  .nav-links a:hover,
  .nav-links a:focus {
    color: var(--blue-9);
  }

  .nav-links a:hover::before,
  .nav-links a:focus::before {
    opacity: 0;
  }

  .nav-links a:hover::after,
  .nav-links a:focus::after {
    transform: scaleX(1);
    transform-origin: left;
  }

  .nav-links a:not(:hover):not(:focus)::after {
    transform: scaleX(0);
    transform-origin: right;
    transition: transform 0.4s ease;
  }

  @media screen and (min-width: 636px) {
    .nav-links {
      gap: 2.5rem;
    }

    .nav-links a {
      font-size: 1.1rem;
    }
  }
</style>

<div id="main-menu" class="nav-links">
  <a href="/">Home</a>

  <a href="/blogs/">Blog</a>
  <a href="/now">Now</a>
</div>
