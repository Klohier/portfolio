---
const { frontmatter } = Astro.props;
import { Image } from "astro:assets";
import Footer from "../components/Footer.astro";
import BaseLayout from "./BaseLayout.astro";

const date = new Date(frontmatter.pubDate);
const formattedDate = date.toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
  timeZone: "UTC",
});

const siteUrl = "https://www.keijilohier.com";
const postUrl = `${siteUrl}${Astro.url.pathname}`;

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  headline: frontmatter.title,
  description: frontmatter.description,
  author: {
    "@type": "Person",
    name: frontmatter.author,
  },
  datePublished: date.toISOString(),
  url: postUrl,
  ...(frontmatter.image?.url && {
    image: `${siteUrl}${frontmatter.image.url}`,
  }),
  ...(frontmatter.tags?.length > 0 && {
    keywords: frontmatter.tags.join(", "),
  }),
};
---

<BaseLayout pageTitle={frontmatter.title} description={frontmatter.description} image={frontmatter.image?.url}>
  <script
    type="application/ld+json"
    slot="head"
    set:html={JSON.stringify(jsonLd)}
  />
  <article class="h-entry">
    <a href={postUrl} class="u-url" hidden></a>
    <header class="post-header">
      <a href="/blogs" class="back-link">← Back to Blog</a>

      {
        frontmatter.image?.url && (
          <Image
            class="post-image"
            src={frontmatter.image.url}
            alt={frontmatter.image.alt}
            width={1200}
            height={630}
          />
        )
      }

      <h1 class="p-name">{frontmatter.title}</h1>
      <p class="p-summary description">{frontmatter.description}</p>

      <div class="meta">
        <time class="date dt-published" datetime={date.toISOString()}>
          {formattedDate}
        </time>
        <span class="author p-author h-card">by {frontmatter.author}</span>
      </div>

      {
        frontmatter.tags?.length > 0 && (
          <ul class="tags">
            {frontmatter.tags.map((tag: string) => (
              <li class="tag">#{tag}</li>
            ))}
          </ul>
        )
      }
    </header>

    <div class="prose e-content">
      <slot />
    </div>

    <Footer />
  </article>
</BaseLayout>

<style>
  article {
    max-width: 150ch;
    margin: 0 auto;
    padding: 1rem 1.5rem 4rem;
  }

  .back-link {
    display: inline-block;
    margin-bottom: 2rem;
    font-size: 0.9rem;
    opacity: 0.75;
    transition: opacity 0.2s;
    color: var(--blue-8);
  }

  .back-link:hover {
    opacity: 1;
    color: var(--blue-9);
  }

  .post-image {
    width: 100%;
    max-height: 360px;
    object-fit: cover;
    border-radius: 8px;
    margin-bottom: 2rem;
  }

  h1 {
    font-size: 2.25rem;
    line-height: 1.2;
    margin: 0 0 0.5rem;
  }

  .description {
    font-size: 1.1rem;
    opacity: 0.8;
    margin: 0 0 1rem;
    font-style: italic;
  }

  .meta {
    display: flex;
    gap: 1rem;
    font-size: 0.875rem;
    opacity: 0.65;
    margin-bottom: 1rem;
  }
</style>
