---
const { frontmatter } = Astro.props;
import BaseLayout from "./BaseLayout.astro";

const date = new Date(frontmatter.pubDate);
const formattedDate = date.toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});
---

<BaseLayout pageTitle={frontmatter.title}>
  <article>
    <header class="post-header">
      <a href="/blog" class="back-link">← Back to Blog</a>

      {
        frontmatter.image?.url && (
          <img
            class="post-image"
            src={frontmatter.image.url}
            alt={frontmatter.image.alt}
          />
        )
      }

      <h1>{frontmatter.title}</h1>
      <p class="description">{frontmatter.description}</p>

      <div class="meta">
        <span class="date">{formattedDate}</span>
        <span class="author">by {frontmatter.author}</span>
      </div>

      {
        frontmatter.tags?.length > 0 && (
          <ul class="tags">
            {frontmatter.tags.map((tag: string) => (
              <li class="tag">#{tag}</li>
            ))}
          </ul>
        )
      }
    </header>

    <div class="prose">
      <slot />
    </div>
  </article>
</BaseLayout>

<style>
  article {
    max-width: 150ch;
    margin: 0 auto;
    padding: 1rem 1.5rem 4rem;
  }

  .back-link {
    display: inline-block;
    margin-bottom: 2rem;
    font-size: 0.9rem;
    opacity: 0.75;
    transition: opacity 0.2s;
  }

  .back-link:hover {
    opacity: 1;
  }

  .post-image {
    width: 100%;
    max-height: 360px;
    object-fit: cover;
    border-radius: 8px;
    margin-bottom: 2rem;
  }

  h1 {
    font-size: 2.25rem;
    line-height: 1.2;
    margin: 0 0 0.5rem;
  }

  .description {
    font-size: 1.1rem;
    opacity: 0.8;
    margin: 0 0 1rem;
    font-style: italic;
  }

  .meta {
    display: flex;
    gap: 1rem;
    font-size: 0.875rem;
    opacity: 0.65;
    margin-bottom: 1rem;
  }

  .tags {
    list-style: none;
    padding: 0;
    margin: 0 0 2.5rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .tag {
    background: rgba(99, 99, 250, 0.2);
    border: 1px solid rgba(99, 99, 250, 0.4);
    color: #a5a5ff;
    font-size: 0.8rem;
    padding: 0.2rem 0.6rem;
    border-radius: 999px;
  }

  .prose {
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    padding-top: 2rem;
    line-height: 1.75;
    font-size: 1.05rem;
  }

  .prose :global(h2),
  .prose :global(h3),
  .prose :global(h4) {
    margin-top: 2rem;
    margin-bottom: 0.5rem;
    line-height: 1.3;
  }

  .prose :global(p) {
    margin: 0 0 1.25rem;
  }

  .prose :global(ul),
  .prose :global(ol) {
    padding-left: 1.5rem;
    margin-bottom: 1.25rem;
  }

  .prose :global(li) {
    margin-bottom: 0.4rem;
  }

  .prose :global(code) {
    background: rgba(255, 255, 255, 0.08);
    padding: 0.15em 0.4em;
    border-radius: 4px;
    font-size: 0.9em;
  }

  .prose :global(pre) {
    background: rgba(0, 0, 0, 0.3);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 8px;
    padding: 1rem 1.25rem;
    overflow-x: auto;
    margin-bottom: 1.25rem;
  }

  .prose :global(pre code) {
    background: none;
    padding: 0;
    font-size: 0.9rem;
  }

  .prose :global(blockquote) {
    border-left: 3px solid rgba(99, 99, 250, 0.6);
    margin: 0 0 1.25rem;
    padding: 0.25rem 0 0.25rem 1.25rem;
    opacity: 0.85;
    font-style: italic;
  }
</style>
