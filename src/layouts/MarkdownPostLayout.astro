---
const { frontmatter } = Astro.props;
import { Image } from "astro:assets";
import BaseLayout from "./BaseLayout.astro";

const date = new Date(frontmatter.pubDate);
const formattedDate = date.toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
  timeZone: "UTC",
});

const siteUrl = "https://www.keijilohier.com";
const postUrl = `${siteUrl}${Astro.url.pathname}`;

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  headline: frontmatter.title,
  description: frontmatter.description,
  author: {
    "@type": "Person",
    name: frontmatter.author,
  },
  datePublished: date.toISOString(),
  url: postUrl,
  ...(frontmatter.image?.url && {
    image: `${siteUrl}${frontmatter.image.url}`,
  }),
  ...(frontmatter.tags?.length > 0 && {
    keywords: frontmatter.tags.join(", "),
  }),
};
---

<BaseLayout pageTitle={frontmatter.title} description={frontmatter.description}>
  <script
    type="application/ld+json"
    slot="head"
    set:html={JSON.stringify(jsonLd)}
  />
  <article class="h-entry">
    <a href={postUrl} class="u-url" hidden></a>
    <header class="post-header">
      <a href="/blogs" class="back-link">← Back to Blog</a>

      {
        frontmatter.image?.url && (
          <Image
            class="post-image"
            src={frontmatter.image.url}
            alt={frontmatter.image.alt}
            width={1200}
            height={630}
          />
        )
      }

      <h1 class="p-name">{frontmatter.title}</h1>
      <p class="p-summary description">{frontmatter.description}</p>

      <div class="meta">
        <time class="date dt-published" datetime={date.toISOString()}>
          {formattedDate}
        </time>
        <span class="author p-author h-card">by {frontmatter.author}</span>
      </div>

      {
        frontmatter.tags?.length > 0 && (
          <ul class="tags">
            {frontmatter.tags.map((tag: string) => (
              <li class="tag">#{tag}</li>
            ))}
          </ul>
        )
      }
    </header>

    <div class="prose e-content">
      <slot />
    </div>

    <footer class="post-cta">
      <p>Want to talk about this post? Reach out I'd love to hear from you.</p>
      <div class="cta-links">
        <a href="mailto:portfolio.uncut584@passmail.net">Email me</a>
        <a
          href="https://mastodon.social/@klohier"
          rel="me noreferrer"
          target="_blank">Mastodon</a
        >
        <a
          href="https://bsky.app/profile/klohier.bsky.social"
          rel="me noreferrer"
          target="_blank">Bluesky</a
        >
      </div>
    </footer>
  </article>
</BaseLayout>

<style>
  article {
    max-width: 150ch;
    margin: 0 auto;
    padding: 1rem 1.5rem 4rem;
  }

  .back-link {
    display: inline-block;
    margin-bottom: 2rem;
    font-size: 0.9rem;
    opacity: 0.75;
    transition: opacity 0.2s;
    color: var(--blue-8);
  }

  .back-link:hover {
    opacity: 1;
    color: var(--blue-9);
  }

  .post-image {
    width: 100%;
    max-height: 360px;
    object-fit: cover;
    border-radius: 8px;
    margin-bottom: 2rem;
  }

  h1 {
    font-size: 2.25rem;
    line-height: 1.2;
    margin: 0 0 0.5rem;
  }

  .description {
    font-size: 1.1rem;
    opacity: 0.8;
    margin: 0 0 1rem;
    font-style: italic;
  }

  .meta {
    display: flex;
    gap: 1rem;
    font-size: 0.875rem;
    opacity: 0.65;
    margin-bottom: 1rem;
  }

  .prose {
    border-top: 1px solid var(--blue-7);
    padding-top: 2rem;
    line-height: 1.75;
    font-size: 1.05rem;
  }

  .prose :global(h2),
  .prose :global(h3),
  .prose :global(h4) {
    margin-top: 2rem;
    margin-bottom: 0.5rem;
    line-height: 1.3;
  }

  .prose :global(p) {
    margin: 0 0 1.25rem;
  }

  .prose :global(ul),
  .prose :global(ol) {
    padding-left: 1.5rem;
    margin-bottom: 1.25rem;
  }

  .prose :global(li) {
    margin-bottom: 0.4rem;
  }

  .prose :global(code) {
    background: var(--blue-9);
    padding: 0.15em 0.4em;
    border-radius: 4px;
    font-size: 0.9em;
  }

  .prose :global(pre) {
    background: var(--blue-1);
    border: 1px solid var(--blue-7);
    border-radius: 8px;
    padding: 1rem 1.25rem;
    overflow-x: auto;
    margin-bottom: 1.25rem;
  }

  .prose :global(pre code) {
    background: none;
    padding: 0;
    font-size: 0.9rem;
  }

  .prose :global(blockquote) {
    border-left: 3px solid var(--blue-7);
    margin: 0 0 1.25rem;
    padding: 0.25rem 0 0.25rem 1.25rem;
    opacity: 0.85;
    font-style: italic;
  }

  .post-cta {
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid var(--blue-7);
    text-align: center;
  }

  .post-cta p {
    font-size: 1rem;
    opacity: 0.8;
    margin-bottom: 1rem;
  }

  .cta-links {
    display: flex;
    justify-content: center;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .cta-links a {
    display: inline-block;
    padding: 0.4rem 1rem;
    border: 1px solid var(--blue-7);
    border-radius: 999px;
    font-size: 0.9rem;
    color: var(--text-color);
    transition:
      background 0.2s,
      border-color 0.2s;
  }

  .cta-links a:hover {
    background: var(--blue-9);
    border-color: var(--blue-8);
    text-decoration: none;
  }
</style>
