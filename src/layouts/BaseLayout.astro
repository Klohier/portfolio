---
import { ClientRouter } from "astro:transitions";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

import "../styles/global.css";
const { pageTitle, description, image } = Astro.props;

const siteUrl = "https://www.keijilohier.com";
const ogImage = image ? `${siteUrl}${image}` : `${siteUrl}/K.png`;
const ogDescription = description ?? "Full Stack Engineer";
---

<html lang="en" class="dark">
  <head>
    <script
      is:inline
      src="https://analytics.ahrefs.com/analytics.js"
      data-key="P4KnFMCyNWjf2qmbU0YJMA"
      async></script>
    <meta charset="utf-8" />
    <link rel="me" href="https://mastodon.social/@klohier" />
    <link class="h-card" href="https://keijilohier.com" />
    <link rel="icon" type="image" href="/K.png" />
    <link
      rel="webmention"
      href="https://webmention.io/keijilohier.com/webmention"
    />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    {description && <meta name="description" content={description} />}
    <!-- Open Graph -->
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={ogDescription} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:url" content={`${siteUrl}${Astro.url.pathname}`} />
    <meta property="og:type" content="website" />
    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={ogDescription} />
    <meta name="twitter:image" content={ogImage} />

    <meta name="fediverse:creator" content="@klohier@mastodon.social" />
    <title>{pageTitle}</title>
    <slot name="head" />
    <ClientRouter />
  </head>
  <body>
    <Header />
    <main>
      <slot />
    </main>
    <Footer />

    <script>
      import "../scripts/menu.js";
    </script>
  </body>
</html>
