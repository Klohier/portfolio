---
import BaseLayout from "../layouts/BaseLayout.astro";
import { Image } from "astro:assets";
import heroImage from "../assets/images/me.jpeg";
import dnbImage from "../assets/images/dotsandboxes.png";
import roulette from "../assets/images/edhswipe.png";
import Envelope from "../assets/icons/envelope-closed.svg";
import GithubLogo from "../assets/icons/github-logo.svg";
import LinkedinLogo from "../assets/icons/linkedin-logo.svg";
import Button from "../components/Button.astro";
import Card from "../components/Card.astro";
import Social from "../components/Social.astro";
const pageTitle = "Keiji Lohier - Portfolio";
---

<script>
  import { gsap } from "gsap";

  document.addEventListener("DOMContentLoaded", () => {
    const gridItems = document.querySelectorAll(".grid > *");

    gsap.from(gridItems, {
      opacity: 0,
      y: 20,
      duration: 0.8,
      stagger: 0.1,
      ease: "power2.out",
    });
  });
</script>

<style>
  .button-group {
    display: flex;
    gap: 1rem;
    margin-top: auto;
    padding-top: 1rem;
  }

  .socials {
    display: flex;
    gap: 1rem;
    margin-top: 1rem;
  }

  .socials a {
    text-decoration: none;
    display: block;
    flex: 1;
  }

  .grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
    margin-bottom: 2rem;
    padding: 0 1rem;
  }

  .hero-section {
    display: flex;
    color: var(--text-color);
  }

  .hero-content {
    margin-bottom: 1rem;
  }

  .hero-section p {
    margin-bottom: 1rem;
    line-height: 1.6;
  }

  .hero-section h1 {
    font-size: 2rem;
    margin-bottom: 1rem;
    text-align: center;
  }

  .hero-image {
    display: block;
    border-radius: 50%;
    margin: 1rem auto;
    width: 200px;
    height: 200px;
    object-fit: cover;
    box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
  }

  .skills-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
    margin-top: 1rem;
  }

  .tags {
    margin-bottom: 1rem;
  }

  .sub {
    font-size: 1.25rem;
    color: var(--secondary-text-color);
    text-align: center;
    margin-top: -0.5rem;
  }

  .tag {
    display: inline-block;
    background-color: var(--primary-color);
    color: var(--accent-color);
    padding: 0.25rem 0.5rem;
    margin-right: 0.5rem;
    margin-bottom: 0.3rem;
    border-radius: 0.25rem;
    font-size: 0.875rem;
  }

  .regular-card :global(img) {
    width: 100%;
    height: 200px;
    object-fit: cover;
    display: block;
    border-radius: 4px;
    margin-bottom: 1rem;
  }

  @media (min-width: 768px) {
    .grid {
      grid-template-columns: repeat(3, 1fr);
      /* grid-template-rows: auto; */
      gap: 1.25rem;
    }

    .hero-section {
      grid-column: span 3;
    }

    .skills-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media (min-width: 1368px) {
    .grid {
      grid-template-columns: repeat(4, 1fr);
      /* grid-template-rows: 1fr 1fr; */
      gap: 0.5rem;
      max-width: 1600px;
      margin: 0 auto 0;
      padding: 1rem 2rem;
    }

    .hero-section {
      grid-column: span 2;
      grid-row: span 2;
    }

    .regular-card {
      grid-column: span 1;
      grid-row: span 1;
    }

    .contact-card {
      grid-column: 3 / 5; /* Columns 3-5 */
      grid-row: 2;
    }
  }
</style>

<BaseLayout pageTitle={pageTitle}>
  <div class="grid">
    <div class="hero-section">
      <Card class="h-card">
        <a href="https://keijilohier.com" class="u-url u-uid" hidden></a>
        <div class="hero-content">
          <h1 class="p-name">Keiji Lohier</h1>
          <p class="sub">Full Stack Engineer</p>
          <Image
            src={heroImage}
            alt="Keiji Lohier"
            width={200}
            height={200}
            class="hero-image u-photo"
          />
          <p class="p-note">
            Hey There! I'm Keiji, a developer passionate about building
            full-stack applications with a focus on backend architecture,
            distributed systems, and DevOps practices.
          </p>

          <p>
            I've been coding since 5th grade, when I built my first text-based
            adventure game using Batch scripting. Today, I'm building full-stack
            applications and exploring distributed systems architecture.
          </p>
        </div>

        <div class="skills-grid">
          <Card>
            <h2>Languages</h2>
            <ul>
              <li>JavaScript (ES6+)</li>
              <li>TypeScript</li>
              <li>HTML5 & CSS3</li>
              <li>Python</li>
              <li>Go</li>
              <li>MySQL</li>
              <li>PostgreSQL</li>
              <li>Java</li>
            </ul>
          </Card>

          <Card>
            <h2>Frameworks & Libraries</h2>
            <ul>
              <li>React</li>
              <li>Node.js & Express</li>
              <li>Astro</li>
              <li>Echo (Go)</li>
            </ul>
          </Card>

          <Card>
            <h2>Tools & Platforms</h2>
            <ul>
              <li>Git & GitHub</li>
              <li>Docker</li>
              <li>VS Code</li>
              <li>Postman</li>
              <li>Webflow</li>
              <li>Proxmox</li>
              <li>Linux</li>
              <li>Figma</li>
              <li>Adobe Creative Cloud</li>
            </ul>
          </Card>
        </div>
      </Card>
    </div>

    <Card class="regular-card">
      <Image
        src={dnbImage}
        alt="gameplay image of dots and boxes."
        layout="constrained"
      />
      <h2>Dots and Boxes</h2>
      <div class="tags">
        <span class="tag">React</span>
        <span class="tag">TypeScript</span>
        <span class="tag">Go</span>
        <span class="tag">PostgreSQL</span>
      </div>
      <p>
        A multiplayer Dots and Boxes game built with React, Tanstack Query, Zod,
        Go, Echo, PostgreSQL. Features real-time gameplay, user authentication,
        and a leaderboard system.
      </p>
      <div class="button-group">
        <Button href="/projects/dnboxes/" name="View Project" />
      </div>
    </Card>

    <Card class="regular-card">
      <Image
        src={roulette}
        alt="Image of Magic Commander Card."
        layout="constrained"
      />
      <h2>EDH Swipe</h2>
      <div class="tags">
        <span class="tag">React</span>
        <span class="tag">TypeScript</span>
        <span class="tag">GSAP</span>
      </div>
      <p>
        An application where users can browse through a deck of commanders and
        choose whether they like them or not. Features ability to view chosen
        commanders later.
      </p>
      <div class="button-group">
        <Button href="/projects/roulette/" name="View Project" />
      </div>
    </Card>
    <div class="contact-card">
      <Card>
        <h2>Get In Touch</h2>
        <p>
          I'm always open to discussing new projects, creative ideas, or
          opportunities to be part of your visions. Feel free to reach out to me
          through my social media channels or send me an email directly.
        </p>
        <div class="socials">
          <Social href="https://github.com/klohier" label="GitHub">
            <GithubLogo />
          </Social>
          <Social
            href="https://www.linkedin.com/in/keiji-lohier/"
            label="LinkedIn"
          >
            <LinkedinLogo />
          </Social>
          <Social
            href="mailto:portfolio.uncut584@passmail.net"
            label="Email"
            rel="me"
          >
            <Envelope />
          </Social>
        </div>
      </Card>
    </div>
  </div>
</BaseLayout>
