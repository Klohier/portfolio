---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import BlogPost from "../components/BlogPost.astro";

const allPosts = (await getCollection("blogs")).sort(
  (postA, postB) => postB.data.pubDate.getTime() - postA.data.pubDate.getTime(),
);

const pageTitle = "Blog";

const siteUrl = "https://keijilohier.com";

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  name: pageTitle,
  url: `${siteUrl}/blogs`,
  hasPart: allPosts.map((post) => ({
    "@type": "BlogPosting",
    headline: post.data.title,
    author: {
      "@type": "Person",
      name: post.data.author,
    },
    description: post.data.description,
    datePublished: post.data.pubDate,
    url: `${siteUrl}/blogs/${post.id}`,
    ...(post.data.image?.url && {
      image: `${siteUrl}${post.data.image.url}`,
    }),
  })),
};
---

<style>
  .posts {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    margin-top: 1.5rem;
    margin-bottom: 4rem;
  }
</style>

<BaseLayout pageTitle={pageTitle}>
  <script
    type="application/ld+json"
    is:inline
    slot="head"
    set:html={JSON.stringify(jsonLd)}
  />
  <section>
    <h1>What I'm Up To</h1>

    <div class="posts">
      {
        allPosts.map((post) => (
          <BlogPost
            url={`/blogs/${post.id}`}
            title={post.data.title}
            image={post.data.image}
            description={post.data.description}
            pubDate={post.data.pubDate}
          />
        ))
      }
    </div>
  </section>
</BaseLayout>
